@page "/uniform-contours-series-demo"
@rendermode InteractiveWebAssembly

<PageTitle>Uniform Contours Series Chart</PageTitle>
<h1>Uniform Contours Series Chart</h1>

<p>This page demonstrates uniform contours series in SciChart showing contour lines for 2D data.</p>

<div style="display: flex">
    <div id="demo" style="width: 600px;">
        <SciChartSurface @ref="_sciChartRef" HeightAspect="2" WidthAspect="3">
            <XAxes>
                <NumericAxis />
            </XAxes>
            <YAxes>
                <NumericAxis />
            </YAxes>
            <UniformContoursRenderableSeries
                Id="contours1"
                ColorMap="@colorMap"
                ZStep="10"
                MajorLineStyle="@majorLineStyle"
                MinorLineStyle="@minorLineStyle"
                MinorsPerMajor="3"
                SeriesName="Temperature Contours">
                <ContoursDataLabelProvider
                    IsEnabled="true"
                    LabelRowCount="5"
                    Style="@(new TDataLabelStyle { FontSize = 11 })"
                    Color="white" />
                <UniformHeatmapDataSeries
                    XStart="0"
                    XStep="1"
                    YStart="0"
                    YStep="1"
                    ZValues="@zValues"
                    Metadata="@metadata" />
            </UniformContoursRenderableSeries>
            <MouseWheelZoomModifier />
            <ZoomPanModifier />
        </SciChartSurface>
    </div>
    <div style="margin-left: 20px;">
        <div class="mt-3">
            <h5>Description:</h5>
            <ul style="font-size: 0.9em;">
                <li>Contour lines showing temperature distribution</li>
                <li>Data labels display temperature values from metadata</li>
                <li>LabelRowCount controls the number of label rows (set to 5)</li>
                <li>MetadataSelector formats values as temperature (°C)</li>
                <li>Color gradient: Blue (cold) → Green (medium) → Red (hot)</li>
            </ul>
        </div>
    </div>
</div>
