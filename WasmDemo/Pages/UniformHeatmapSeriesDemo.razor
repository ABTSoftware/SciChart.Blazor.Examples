@page "/uniform-heatmap-series-demo"
@rendermode InteractiveWebAssembly

<PageTitle>Uniform Heatmap Series Chart</PageTitle>
<h1>Uniform Heatmap Series Chart</h1>

<p>This page demonstrates uniform heatmap series in SciChart showing 2D data visualization.</p>

<div style="display: flex">
    <div id="demo" style="width: 600px;">
        <SciChartSurface @ref="_sciChartRef" HeightAspect="2" WidthAspect="3">
            <XAxes>
                <NumericAxis />
            </XAxes>
            <YAxes>
                <NumericAxis />
            </YAxes>
            <UniformHeatmapRenderableSeries
                Id="heatmap1"
                ColorMap="@colorMap"
                UseLinearTextureFiltering="true"
                SeriesName="Temperature Map">
                <HeatmapDataLabelProvider
                    NumericFormat="ENumericFormat.Decimal"
                    Precision="0"
                    IsEnabled="true"
                    Style="@(new TDataLabelStyle { FontSize = 11, FontFamily = "Arial" })"
                    Color="white" />
                <UniformHeatmapDataSeries
                    XStart="0"
                    XStep="1"
                    YStart="0"
                    YStep="1"
                    ZValues="@zValues" />
            </UniformHeatmapRenderableSeries>
            <MouseWheelZoomModifier />
            <ZoomPanModifier />
        </SciChartSurface>
    </div>
    <div style="margin-left: 20px;">
        <div class="mt-3">
            <h5>Description:</h5>
            <ul style="font-size: 0.9em;">
                <li>Heatmap showing temperature distribution</li>
                <li>Data labels display Z values (temperature)</li>
                <li>NumericFormat set to Decimal with Precision 0</li>
                <li>Linear texture filtering for smooth color interpolation</li>
                <li>Color gradient: Blue (cold) → Green (medium) → Red (hot)</li>
            </ul>
        </div>
    </div>
</div>
