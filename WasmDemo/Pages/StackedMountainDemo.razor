@page "/stacked-mountain-demo"
@rendermode InteractiveWebAssembly

<PageTitle>Stacked Mountain Chart</PageTitle>

<h1>Stacked Mountain Chart</h1>

<p>This example demonstrates stacked mountain (area) charts with multiple series stacking on top of each other.</p>
<div style="display: flex">
    <div id="demo" style="width: 600px;">
        <SciChartSurface @ref="_sciChartRef" HeightAspect="2" WidthAspect="3">
            <XAxes>
                <NumericAxis Id="xAxis" AxisTitle="X Axis" VisibleRange="@(new NumberRange { Min = 0, Max = 12 })" />
            </XAxes>
            <YAxes>
                <NumericAxis Id="yAxis" AxisTitle="Y Axis" />
            </YAxes>

            <StackedMountainCollection IsOneHundredPercent="@_isOneHundredPercent" XAxisId="xAxis" YAxisId="yAxis">
                <StackedMountainRenderableSeries
                    Id="series1"
                    Fill="rgba(70, 130, 180, 0.5)"
                    Stroke="#4682B4"
                    StrokeThickness="1"
                    SeriesName="Series 1">
                    <XyDataSeries @ref="_xyDataSeriesSeries1Ref" XValues="@_xData" YValues="@_yData1" />
                </StackedMountainRenderableSeries>

                <StackedMountainRenderableSeries
                    Id="series2"
                    Fill="rgba(255, 140, 0, 0.5)"
                    Stroke="#FF8C00"
                    StrokeThickness="1"
                    SeriesName="Series 2">
                    <XyDataSeries @ref="_xyDataSeriesSeries2Ref" XValues="@_xData" YValues="@_yData2" />
                </StackedMountainRenderableSeries>

                <StackedMountainRenderableSeries
                    Id="series3"
                    Fill="rgba(50, 205, 50, 0.5)"
                    Stroke="#32CD32"
                    StrokeThickness="1"
                    SeriesName="Series 3">
                    <XyDataSeries @ref="_xyDataSeriesSeries3Ref" XValues="@_xData" YValues="@_yData3" />
                </StackedMountainRenderableSeries>
            </StackedMountainCollection>

            <MouseWheelZoomModifier />
            <ZoomPanModifier />
        </SciChartSurface>
    </div>
    <div style="margin-left: 20px;">
        <button id="btn-append-data" type="button" class="btn btn-secondary mt-2" @onclick="AppendData">
            Append Data
        </button>
        <br />
        <button type="button" class="btn btn-secondary mt-2" @onclick="AppendDataByPointer">
            Append Data By Pointer
        </button>
        <br />
        <div class="mt-3">
            <label>
                <input type="checkbox" @bind="_isOneHundredPercent" @bind:after="OnStackingModeChanged" />
                Use 100% Stacking Mode
            </label>
        </div>
        <div class="mt-3">
            <h5>Description:</h5>
            <ul style="font-size: 0.9em;">
                <li>Three stacked mountain series</li>
                <li>Toggle between standard and 100% stacking</li>
                <li>Append data updates all series together</li>
            </ul>
        </div>
    </div>
</div>
